{
  "name": "database-design",
  "private": true,
  "workspaces": [
    "packages/frontend",
    "packages/backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/backend\" \"npm run dev --workspace=packages/frontend\"",
    "dev:fe": "npm run dev --workspace=packages/frontend",
    "dev:be": "npm run dev --workspace=packages/backend",
    "build": "npm run build --workspace=packages/frontend",
    "test": "npm run test --workspace=packages/frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
